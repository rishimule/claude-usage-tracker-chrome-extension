{
  "manifest_version": 3,
  "name": "Claude Usage Tracker",
  "version": "0.1.2",
  "description": "Persistent footer showing Claude plan + usage on claude.ai and console.anthropic.com.",
  "icons": {
    "16": "icons/16.png",
    "32": "icons/32.png",
    "48": "icons/48.png",
    "128": "icons/128.png"
  },
  "background": { "service_worker": "background.js", "type": "module" },
  "permissions": ["activeTab", "scripting", "storage", "alarms"],
  "host_permissions": ["*://*.claude.ai/*", "*://console.anthropic.com/*"],
  "content_scripts": [
    {
      "matches": ["*://*.claude.ai/*", "*://console.anthropic.com/*"],
      "js": ["page-context.js"],
      "run_at": "document_start",
      "all_frames": false,
      "world": "MAIN"
    },
    {
      "matches": ["*://*.claude.ai/*", "*://console.anthropic.com/*"],
      "js": ["content.js"],
      "css": [],
      "run_at": "document_end",
      "all_frames": false,
      "world": "ISOLATED"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["footer.css", "footer.html"],
      "matches": ["*://*.claude.ai/*", "*://console.anthropic.com/*"]
    }
  ]
}
